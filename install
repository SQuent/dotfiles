#!/usr/bin/env bash

set -e

DOTBOT_DIR="dotbot/dotbot"
START_TIME=$(date +%s)
DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOGFILE="${BASEDIR}/install.log"

log() {
    echo "$1" | tee -a "$LOGFILE"
}

OS="$(uname -s)"
log "Starting script at $(date)"
log "Detected OS: ${OS}"


# Move to base directory
log "Changing to base directory: ${BASEDIR}"
cd "${BASEDIR}"

# Source config profile if it exists
log "Sourcing config/.profile if it exists..."
if [ -f config/.profile ]; then
    source config/.profile
    log "Sourced config/.profile"
fi

# Sync git submodules
log "Synchronizing git submodules..."
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive 2>&1 | tee -a "$LOGFILE"
git submodule update --init --recursive 2>&1 | tee -a "$LOGFILE"

# ─── macOS ────────────────────────────────────────────────────────────────────
if [[ "$OS" == "Darwin" ]]; then

    # Ensure Xcode Command Line Tools are installed (required for git, make, etc.)
    if ! xcode-select -p &>/dev/null; then
        log "Xcode Command Line Tools not found. Triggering installation..."
        xcode-select --install
        log "Please re-run this script once Xcode CLT installation has completed."
        exit 0
    fi

    # Add Homebrew to PATH for this session (handles both Apple Silicon and Intel)
    if [[ -d "/opt/homebrew/bin" ]]; then
        export PATH="/opt/homebrew/bin:$PATH"   # Apple Silicon
    elif [[ -d "/usr/local/bin" ]]; then
        export PATH="/usr/local/bin:$PATH"      # Intel
    fi

    # Pass 1: common config (clean, create, link, install-brew, tap, brew, shell)
    log "Running Dotbot for common config..."
    "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" \
        --plugin-dir dotbot/dotbot-brew \
        -v -c common.conf.yaml 2>&1 | tee -a "$LOGFILE"
    log "Dotbot (common) done."

    # Pass 2: macOS-specific config (trash, gnupg, ~/Library/Fonts link)
    log "Running Dotbot for macOS-specific config..."
    "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" \
        --plugin-dir dotbot/dotbot-brew \
        -v -c mac.conf.yaml 2>&1 | tee -a "$LOGFILE"
    log "Dotbot (mac) done."

# ─── Linux ────────────────────────────────────────────────────────────────────
elif [[ "$OS" == "Linux" ]]; then

    # Bootstrap: ensure curl, python3, python3-dev and git are present before dotbot
    log "Updating package lists..."
    sudo apt-get update 2>&1 | tee -a "$LOGFILE"
    sudo apt-get upgrade --yes 2>&1 | tee -a "$LOGFILE"

    for pkg in curl python3 git; do
        if ! command -v "$pkg" &>/dev/null; then
            log "${pkg} not found. Installing..."
            sudo apt-get --yes install "$pkg" 2>&1 | tee -a "$LOGFILE"
        else
            log "${pkg} already installed. Skipping."
        fi
    done

    if ! dpkg -s python3-dev &>/dev/null 2>&1; then
        log "python3-dev not found. Installing..."
        sudo apt-get --yes install python3-dev 2>&1 | tee -a "$LOGFILE"
    else
        log "python3-dev already installed. Skipping."
    fi

    # Add Linuxbrew to PATH for this session
    export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"

    # Pass 1: apt packages (requires sudo, uses linux-specific config)
    log "Running Dotbot for apt (Linux)..."
    sudo "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" \
        --plugin-dir dotbot/dotbot-apt \
        --only apt -v -c linux.conf.yaml 2>&1 | tee -a "$LOGFILE"
    log "Dotbot (apt) done."

    # Pass 2: common config (clean, create, link, install-brew, tap, brew, shell)
    log "Running Dotbot for common config..."
    "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" \
        --plugin-dir dotbot/dotbot-apt \
        --plugin-dir dotbot/dotbot-brew \
        -v -c common.conf.yaml 2>&1 | tee -a "$LOGFILE"
    log "Dotbot (common) done."

    # Pass 3: Linux-specific brew + shell (sudoers, chsh, fc-cache)
    log "Running Dotbot for Linux-specific config (except apt)..."
    "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" \
        --plugin-dir dotbot/dotbot-apt \
        --plugin-dir dotbot/dotbot-brew \
        --except apt -v -c linux.conf.yaml 2>&1 | tee -a "$LOGFILE"
    log "Dotbot (linux) done."

else
    log "Unsupported OS: ${OS}"
    exit 1
fi

# Calculer le temps écoulé
total_time=$(( $(date +%s) - START_TIME ))
if [[ $total_time -gt 60 ]]; then
    total_time="$(( total_time / 60 )) minutes"
else
    total_time="${total_time} seconds"
fi

log "Script completed in $total_time"